{
  "name": "dpi-guardians",
  "version": "1.0.0",
  "description": "AI agent swarm that autonomously maintains libp2p as Digital Public Infrastructure",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.ts --network localhost",
    "node": "hardhat node",
    "register-agents": "ts-node scripts/register-agents.ts",
    "seed": "ts-node scripts/seed-data.ts",
    "demo": "ts-node scripts/demo.ts",
    "swarm": "ts-node orchestrator/SwarmOrchestrator.ts",
