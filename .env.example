# Network
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# AI Inference — Anthropic Claude (optional, not needed in mock mode)
# ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY
# ANTHROPIC_MODEL=claude-sonnet-4-6

# GitHub (for PR review, optional in mock mode)
# GH_TOKEN=ghp_YOUR_GITHUB_TOKEN
GITHUB_ORG=libp2p

# Contract addresses (populated after deploy)
TIPPING_SYSTEM_ADDRESS=
BRIBE_ESCROW_ADDRESS=
STREAMING_AGREEMENT_ADDRESS=
TREASURY_ADDRESS=
ERC8004_REGISTRY_ADDRESS=

# Filecoin/IPFS storage
FILECOIN_API_KEY=YOUR_FILECOIN_KEY
STORAGE_MODE=local   # "local" for demo, "filecoin" for production

# Demo settings — all mocked, no API keys needed
DEMO_MODE=true
MOCK_GITHUB=true
MOCK_UNISWAP=true
MOCK_LLM=true
